# PostgreSQL connection used by backend
# Replace placeholders with your local credentials.
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@localhost:5432/<db_name>

# Crawler schedule (cron, default: 2am daily)
CRAWLER_SCHEDULE=0 2 * * *

# LLM server (OpenAI-compatible API)
LLM_BASE_URL=http://127.0.0.1:8082
LLM_MODEL=Qwen3.5-27B-Q4_K_M.gguf
